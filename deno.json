{
  "unstable": ["temporal", "kv"],
  "tasks": {
    "test": "deno test --allow-env --unstable-temporal --unstable-kv",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "include": ["src/", "ROADMAP.md"]
  },
  "lint": {
    "include": ["src/"],
    "rules": {
      "tags": ["recommended"]
      // NOTE: A custom rule forbidding direct Date.now()/new Date() calls in
      // domain code (in favor of the Clock abstraction) is added in Task 1.2.
      // This placeholder documents the intent; no custom rule is wired up yet.
    }
  },
  "imports": {}
}
