{
  "unstable": ["temporal", "kv"],
  "tasks": {
    "test": "deno test --allow-env --allow-read --allow-write --unstable-temporal --unstable-kv",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check:no-date": "deno run --allow-read scripts/no_direct_date_check.ts src",
    "check": "deno check src && deno task check:no-date"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "include": ["src/", "scripts/", "ROADMAP.md"]
  },
  "lint": {
    "include": ["src/", "scripts/"],
    "rules": {
      "tags": ["recommended"]
      // NOTE: Deno's custom lint plugin API cannot express the "no direct
      // Date.now()/new Date()/Temporal.Now outside the Clock abstraction"
      // rule (FR-008), so it is enforced instead by
      // scripts/no_direct_date_check.ts, wired into `deno task check` as
      // `check:no-date` (see Task 1.2).
    }
  },
  "imports": {
    "zod": "npm:zod@3.25.76",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.29.0",
    "@modelcontextprotocol/sdk/": "npm:/@modelcontextprotocol/sdk@^1.29.0/"
  }
}
